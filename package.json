{
  "name": "@eidra-umain/greenlight",
  "version": "0.7.0",
  "description": "E2E web testing tool — write tests as plain English, no selectors or glue code",
  "license": "MIT",
  "author": "umain.com",
  "type": "module",
  "main": "dist/cli/index.js",
  "exports": {
    ".": "./dist/cli/index.js",
    "./*": "./dist/*"
  },
  "bin": {
    "greenlight": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "e2e",
    "testing",
    "ai",
    "llm",
    "playwright",
    "natural-language",
    "accessibility",
    "automation",
    "end-to-end"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eidra-umain/greenlight"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "greenlight": "node dist/cli/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chrono-node": "^2.9.0",
    "commander": "^13.0.0",
    "dotenv": "^17.3.1",
    "fuse.js": "^7.1.0",
    "human-id": "^4.1.3",
    "playwright": "^1.58.2",
    "playwright-zoom": "^1.1.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
